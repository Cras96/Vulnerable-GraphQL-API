{
  "name": "vulnerable-graphql-api",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "GraphQL API",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "npm install",
  "postAttachCommand": {
    "hint": "echo 'Run: npm run lab   (then open http://localhost:4000/graphql)'"
  },
  "remoteEnv": {
    "TEST_MODE": "LAB_FULLY_VULNERABLE"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "editorconfig.editorconfig",
        "humao.rest-client",
        "graphql.vscode-graphql"
      ],
      "settings": {
        "editor.formatOnSave": false,
        "editor.tabSize": 2,
        "files.eol": "\n"
      }
    }
  }
}
