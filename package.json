{
  "name": "vulnerable-graphql-api",
  "version": "1.0.0",
  "description": "Healthcare GraphQL API used as a security testbed.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lab": "cross-env TEST_MODE=LAB_FULLY_VULNERABLE node src/server.js",
    "pentest": "cross-env TEST_MODE=PENTEST_REALISTIC node src/server.js",
    "hardened": "cross-env TEST_MODE=BASELINE_HARDENED node src/server.js",
    "lint": "eslint src/",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "private": false,
  "license": "MIT",
  "author": "Iosif Vlachakis",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cras96/Vulnerable-GraphQL-API.git"
  },
  "dependencies": {
    "apollo-server": "^3.13.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "graphql": "^16.8.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "nodemon": "^3.0.2"
  }
}
